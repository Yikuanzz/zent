{
  "name": "zent",
  "version": "0.1.0",
  "description": "zent — a minimal local coding agent for learning AI agent internals: Ink TUI + native tool calling over an OpenAI-compatible API.",
  "type": "module",
  "bin": {
    "zent": "./bin/cli.tsx"
  },
  "scripts": {
    "dev": "bun run bin/cli.tsx",
    "headless": "bun run scripts/runHeadless.ts",
    "test": "bun test",
    "build": "bun build --compile bin/cli.tsx --outfile zent"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "fast-glob": "^3.3.2",
    "ignore": "^6.0.2",
    "ink": "^5.1.0",
    "openai": "^4.77.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
